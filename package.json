{
  "name": "signalworks",
  "version": "1.0.0",
  "private": true,
  "description": "A browser puzzle game where you write tiny assembly programs for in-game chips.",
  "type": "module",
  "license": "MIT",
  "author": "Charlie Krug",
  "repository": {
    "type": "git",
    "url": "https://github.com/ctkrug/signalworks.git"
  },
  "keywords": [
    "game",
    "puzzle",
    "assembly",
    "canvas",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.0",
    "fast-check": "^3.23.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
